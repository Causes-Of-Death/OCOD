        <dc:date xml:lang="en">03-17-2026</dc:date>
        <dc:description xml:lang="en">OCOD is a biomedical ontology in the area of causes of death.</dc:description>
        <dc:format xml:lang="en">OWL-DL</dc:format>
        <dc:subject xml:lang="en">OCOD: A biomedical ontology in the area of causes of death</dc:subject>
        <dc:title xml:lang="en">OCOD: Ontology of Causes of Death</dc:title>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-5139-5557"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-5809-9523"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-8910-9851"/>
