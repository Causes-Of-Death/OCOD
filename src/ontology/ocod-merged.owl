    <!-- http://purl.obolibrary.org/obo/CHEBI_9123 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_9123">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23132"/>
