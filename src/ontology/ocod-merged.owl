        <terms:contributor rdf:resource="https://orcid.org/0000-0002-7356-1779"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-8457-6693"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-8688-6599"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-8844-9165"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-1640-9989"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4423-4370"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4871-5569"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0009-4008-3801"/>
        <terms:description xml:lang="en">COB brings together key terms from a wide range of OBO projects to improve interoperability.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0/"/>
        <terms:title xml:lang="en">Core Ontology for Biology and Biomedicine</terms:title>
        <owl:versionInfo>2025-12-12</owl:versionInfo>
        <owl:versionInfo xml:lang="en">Vision Release: 1.0.02</owl:versionInfo>
    </owl:Ontology>
    


