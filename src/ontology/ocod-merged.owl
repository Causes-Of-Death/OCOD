        <obo:IAO_0000115 xml:lang="en">A molecule that consists of nucleotides (unmodified nucleotide residues and/or modified nucleotide residues) linked by phosphodiester bonds or derivatives of such bonds.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">nucleic acid chain</rdfs:label>
    </owl:Class>
    


