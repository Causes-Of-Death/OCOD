        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_46848"/>
        <obo:IAO_0000115>An &lt;em&gt;N&lt;/em&gt;-arylpiperazine in which one nitrogen is substituted by a 3-chlorophenyl group, while the other is substituted by a 3-(3-oxo[1,2,4]triazolo[4,3-&lt;em&gt;a&lt;/em&gt;]pyridin-2(3&lt;em&gt;H&lt;/em&gt;)-yl)propyl group.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/chebi.owl"/>
        <oboInOwl:hasDbXref>beilstein:628010</oboInOwl:hasDbXref>
