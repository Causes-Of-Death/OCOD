        <oboInOwl:hasRelatedSynonym>(5R,6S,9R,13S,14R)-4,5-epoxy-N-methyl-7-morphinen-3,6-diol</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasDbXref>pubmed:24306419</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>knapsack:C00001889</oboInOwl:hasDbXref>
