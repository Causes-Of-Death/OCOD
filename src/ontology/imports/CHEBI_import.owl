    <!-- http://purl.obolibrary.org/obo/CHEBI_35681 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_35681">
        <rdfs:label>secondary alcohol</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30879"/>
        <chemrof:charge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</chemrof:charge>
        <chemrof:monoisotopic_mass rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">30.01056</chemrof:monoisotopic_mass>
        <chemrof:mass rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">30.026</chemrof:mass>
        <oboInOwl:hasAlternativeId>CHEBI:9077</oboInOwl:hasAlternativeId>
        <oboInOwl:hasDbXref>kegg.compound:C01612</oboInOwl:hasDbXref>
        <chemrof:generalized_empirical_formula>CH2OR2</chemrof:generalized_empirical_formula>
        <oboInOwl:hasRelatedSynonym>R-CHOH-R&#39;</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasAlternativeId>CHEBI:58662</oboInOwl:hasAlternativeId>
        <oboInOwl:hasRelatedSynonym>Secondary alcohol</oboInOwl:hasRelatedSynonym>
        <obo:IAO_0000115>A secondary alcohol is a compound in which a hydroxy group, ‒OH, is attached to a saturated carbon atom which has two other carbon atoms attached to it.</obo:IAO_0000115>
