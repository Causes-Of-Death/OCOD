    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24651">
        <rdfs:label>hydroxides</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25806"/>
