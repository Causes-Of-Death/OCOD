        <oboInOwl:hasDbXref>vsdb:2982</oboInOwl:hasDbXref>
        <chemrof:smiles_string>[H][C@@]12C=C[C@H](O)[C@@H]3Oc4c(O)ccc5c4[C@@]31CCN(C)[C@@H]2C5</chemrof:smiles_string>
        <oboInOwl:hasExactSynonym>17-methyl-7,8-didehydro-4,5alpha-epoxymorphinan-3,6alpha-diol</oboInOwl:hasExactSynonym>
        <oboInOwl:hasAlternativeId>CHEBI:7001</oboInOwl:hasAlternativeId>
        <oboInOwl:hasDbXref>cas:57-27-2</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>pdb:1Q0Y</oboInOwl:hasDbXref>
        <oboInOwl:hasRelatedSynonym>(-)-morphine</oboInOwl:hasRelatedSynonym>
        <obo:IAO_0000115>A morphinane alkaloid that is a highly potent opiate analgesic psychoactive drug. Morphine acts directly on the central nervous system (CNS) to relieve pain but has a high potential for addiction, with tolerance and both physical and psychological dependence developing rapidly. Morphine is the most abundant opiate found in &lt;em&gt;Papaver somniferum&lt;/em&gt; (the opium poppy).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>pubmed:23555556</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>pubmed:20071451</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>kegg.drug:D08233</oboInOwl:hasDbXref>
        <chemrof:inchi_string>InChI=1S/C17H19NO3/c1-18-7-6-17-10-3-5-13(20)16(17)21-15-12(19)4-2-9(14(15)17)8-11(10)18/h2-5,10-11,13,16,19-20H,6-8H2,1H3/t10-,11+,13-,16-,17-/m0/s1</chemrof:inchi_string>
        <oboInOwl:hasRelatedSynonym>(5alpha,6alpha)-didehydro-4,5-epoxy-17-methylmorphinan-3,6-diol</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>(7R,7AS,12BS)-3-METHYL-2,3,4,4A,7,7A-HEXAHYDRO-1H-4,12-METHANO[1]BENZOFURO[3,2-E]ISOQUINOLINE-7,9-DIOL</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>Morphia</oboInOwl:hasRelatedSynonym>
